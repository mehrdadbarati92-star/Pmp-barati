/* ============================================================
   UTILITIES
   ============================================================ */
function $(sel){return document.querySelector(sel)}
function $all(sel){return Array.from(document.querySelectorAll(sel))}
function toFa(num){
  const map={'0':'۰','1':'۱','2':'۲','3':'۳','4':'۴','5':'۵','6':'۶','7':'۷','8':'۸','9':'۹'};
  return String(num).replace(/[0-9]/g,d=>map[d]);
}
function esc(str){
  const d=document.createElement('div'); d.textContent=String(str); return d.innerHTML;
}
function fmtTime(totalSec){
  const m=Math.floor(totalSec/60), s=totalSec%60;
  return toFa(String(m).padStart(2,'0'))+':'+toFa(String(s).padStart(2,'0'));
}
function showScreen(id){
  $all('.screen').forEach(s=>s.classList.remove('active'));
  $('#'+id).classList.add('active');
  window.scrollTo(0,0);
}
function openModal(title,text,confirmLabel,cancelLabel,onConfirm){
  $('#modal-title').textContent=title;
  $('#modal-text').textContent=text;
  $('#modal-confirm').textContent=confirmLabel;
  $('#modal-cancel').textContent=cancelLabel;
  $('#modal-cancel').style.display = cancelLabel ? '' : 'none';
  $('#modal-overlay').classList.add('active');
  $('#modal-confirm').onclick=()=>{ $('#modal-overlay').classList.remove('active'); onConfirm && onConfirm(); };
  $('#modal-cancel').onclick=()=>{ $('#modal-overlay').classList.remove('active'); };
}

/* ============================================================
   BRANDING — اعمال تنظیمات برند در همه صفحات
   ============================================================ */
function applyBranding(){
  ['login','exam','report'].forEach(scope=>{
    const nameEl=$('#org-name-'+scope), subEl=$('#org-sub-'+scope), logoEl=$('#logo-mark-'+scope);
    if(nameEl) nameEl.textContent=CONFIG.orgName;
    if(subEl) subEl.textContent=CONFIG.orgSubtitle;
    if(logoEl && CONFIG.logoUrl){ logoEl.innerHTML='<img src="'+CONFIG.logoUrl+'" alt="logo">'; }
  });
  $('#exam-title-text').textContent=DATA.examTitle;
  $('#exam-case-text').textContent=DATA.caseName;
  $('#meta-duration').textContent=toFa(CONFIG.examDurationMinutes);
  $('#meta-stages').textContent=toFa(DATA.stages.length);
}

